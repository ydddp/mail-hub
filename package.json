{
  "name": "mail-hub",
  "version": "0.9.0",
  "private": true,
  "description": "Multi-provider temporary email aggregation service with unified API and verification code extraction.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/ydddp/mail-hub.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node --input-type=commonjs -e \"require('fs').cpSync('src/public','dist/public',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "hono": "^4.7.4",
    "imapflow": "^1.3.3",
    "nanoid": "^5.1.2",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
